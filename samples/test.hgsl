vertex vert = fn void{
	@position = .{vertex_buffer[@vertex_id], 1} 
}

fragment frag = fn f32x4 {
	const scalar = 9
	const fef = fn(x: compint) compint{}
	const ds = double(compint, scalar, 9)
	const color: f32x3 = .{ds}
	return .{color, 1}
}

