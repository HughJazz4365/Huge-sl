//const FUNC = fn(T: type, comptime t: T, A : fn(t:T) type{...}(t)) A{...}
push vertex_buffer: *f32x3

const double = fn(T: type, x: T) @TypeOf(x) {
	return x * 2
}


vertex vert = fn void{
	@position = .{vertex_buffer[@vertex_id], 1} 
}

fragment frag = fn f32x4 {
	const scalar = 9
	const ds = double(compint, scalar)
	const color: f32x3 = .{ds}
	return .{color, 1}
}

